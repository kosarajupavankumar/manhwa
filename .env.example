# ─── Webtoon Pipeline Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Full URL of the webtoon episode-list page (REQUIRED)
WEBTOONS_URL=

# ─── Scraper ──────────────────────────────────────────────────────────────────

# Episode number to start from (default: 1)
FROM_EPISODE=1

# Episode number to stop at — leave blank to scrape all episodes
TO_EPISODE=

# Directory where downloaded images are saved (default: ./downloads)
DOWNLOAD_DIR=./downloads

# ─── OCR ──────────────────────────────────────────────────────────────────────

# Directory where extracted .txt files are written (default: ./output)
OCR_OUTPUT_DIR=./output

# Number of parallel Tesseract workers (default: 2)
OCR_CONCURRENCY=2

# Tesseract language code (default: eng)
OCR_LANG=eng

# Set to "true" to invert image colours before OCR (for dark-mode panels)
OCR_INVERT=false

# ─── Pipeline ─────────────────────────────────────────────────────────────────

# Set to "true" to download images only and skip OCR
SKIP_OCR=false

# ─── General ──────────────────────────────────────────────────────────────────

# Set to "true" to print stack traces on errors
DEBUG=false
