# Google AI API Key (required for Gemini OCR and script generation)
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (optional, used as fallback for script generation and TTS)
OPENAI_API_KEY=your_openai_api_key_here

# RunwayML API Key (optional, for AI video generation)
RUNWAYML_API_KEY=your_runwayml_api_key_here

# ElevenLabs API Key (optional, for high-quality TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Default limit for episodes to process
WEBTOON_LIMIT=10